// select11.jsonl — SELECT focusing on underrepresented tables
// appointment
{"nl": "show all appointments", "intent": "select", "table": "appointment"}
{"nl": "list appointment status and scheduled date", "intent": "select", "table": "appointment", "projections": ["status", "scheduled"]}
{"nl": "get confirmed appointments", "intent": "select", "table": "appointment", "conditions": [{"field": "status", "cmp": "eq", "value": "confirmed"}]}
{"nl": "show appointment notes and status", "intent": "select", "table": "appointment", "projections": ["notes", "status"]}
{"nl": "find pending appointments", "intent": "select", "table": "appointment", "conditions": [{"field": "status", "cmp": "eq", "value": "pending"}]}
{"nl": "list appointments where notes contains follow", "intent": "select", "table": "appointment", "conditions": [{"field": "notes", "cmp": "contains", "value": "follow"}]}
{"nl": "get cancelled appointment scheduled dates", "intent": "select", "table": "appointment", "projections": ["scheduled"], "conditions": [{"field": "status", "cmp": "eq", "value": "cancelled"}]}
{"nl": "show appointment status and notes sorted by scheduled", "intent": "select", "table": "appointment", "projections": ["status", "notes"], "modifiers": [{"type": "order_by", "field": "scheduled"}]}
{"nl": "get appointments where status is <val>", "intent": "select", "table": "appointment", "conditions": [{"field": "status", "cmp": "eq"}]}
{"nl": "list appointment scheduled date and status where notes contains <val>", "intent": "select", "table": "appointment", "projections": ["scheduled", "status"], "conditions": [{"field": "notes", "cmp": "contains"}]}
