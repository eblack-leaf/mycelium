// select13.jsonl — Complex SELECT: projections + conditions + ORDER BY + LIMIT combined
// employee
{"nl": "get top 10 employees by salary descending", "intent": "select", "table": "employee", "projections": ["name", "salary"], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}, {"type": "limit", "value": "10"}]}
{"nl": "show active employees name and salary sorted by salary descending limit 20", "intent": "select", "table": "employee", "projections": ["name", "salary"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}, {"type": "limit", "value": "20"}]}
{"nl": "list employees in department <val> sorted by name limit 5", "intent": "select", "table": "employee", "projections": ["name", "role"], "conditions": [{"field": "department", "cmp": "eq"}], "modifiers": [{"type": "order_by", "field": "name"}, {"type": "limit", "value": "5"}]}
{"nl": "find top 5 highest paid employees sorted by salary descending", "intent": "select", "table": "employee", "projections": ["name", "salary", "department"], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}, {"type": "limit", "value": "5"}]}
