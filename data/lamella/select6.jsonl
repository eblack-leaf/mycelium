// select6.jsonl — multi-condition SELECT with projections (stress test cond_field + proj together)
// employee
{"nl": "show name and salary for active employees in engineering earning above 60000", "intent": "select", "table": "employee", "projections": ["name", "salary"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "department", "cmp": "eq", "value": "engineering"}, {"field": "salary", "cmp": "gt", "value": "60000"}]}
{"nl": "get name email and role where active is true and role is manager", "intent": "select", "table": "employee", "projections": ["name", "email", "role"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "role", "cmp": "eq", "value": "manager"}]}
{"nl": "list name department salary where department is sales and salary less than 50000", "intent": "select", "table": "employee", "projections": ["name", "department", "salary"], "conditions": [{"field": "department", "cmp": "eq", "value": "sales"}, {"field": "salary", "cmp": "lt", "value": "50000"}]}
{"nl": "fetch active employees in hr show name and email", "intent": "select", "table": "employee", "projections": ["name", "email"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "department", "cmp": "eq", "value": "hr"}]}
// product
{"nl": "show name price and sku for active products with price below 100", "intent": "select", "table": "product", "projections": ["name", "price", "sku"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "price", "cmp": "lt", "value": "100"}]}
{"nl": "get name and stock where active and stock greater than 50", "intent": "select", "table": "product", "projections": ["name", "stock"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "stock", "cmp": "gt", "value": "50"}]}
{"nl": "list name price category where price above 20 and price below 200", "intent": "select", "table": "product", "projections": ["name", "price", "category"], "conditions": [{"field": "price", "cmp": "gt", "value": "20"}, {"field": "price", "cmp": "lt", "value": "200"}]}
{"nl": "fetch active products with stock below 10 show name and sku", "intent": "select", "table": "product", "projections": ["name", "sku"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "stock", "cmp": "lt", "value": "10"}]}
// student
{"nl": "show name email and gpa for enrolled students with gpa above 3.0", "intent": "select", "table": "student", "projections": ["name", "email", "gpa"], "conditions": [{"field": "enrolled", "cmp": "eq", "value": "true"}, {"field": "gpa", "cmp": "gt", "value": "3.0"}]}
{"nl": "get name and gpa where enrolled is false and gpa below 2.0", "intent": "select", "table": "student", "projections": ["name", "gpa"], "conditions": [{"field": "enrolled", "cmp": "eq", "value": "false"}, {"field": "gpa", "cmp": "lt", "value": "2.0"}]}
{"nl": "list name email enrolled where gpa above 3.5 and enrolled is true", "intent": "select", "table": "student", "projections": ["name", "email", "enrolled"], "conditions": [{"field": "gpa", "cmp": "gt", "value": "3.5"}, {"field": "enrolled", "cmp": "eq", "value": "true"}]}
// doctor
{"nl": "show name and specialty for active doctors with rating above 4.5", "intent": "select", "table": "doctor", "projections": ["name", "specialty"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "rating", "cmp": "gt", "value": "4.5"}]}
{"nl": "get name email and rating where active and specialty is cardiology", "intent": "select", "table": "doctor", "projections": ["name", "email", "rating"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "specialty", "cmp": "eq", "value": "cardiology"}]}
{"nl": "fetch doctors with rating above 4 and active true show name and specialty", "intent": "select", "table": "doctor", "projections": ["name", "specialty"], "conditions": [{"field": "rating", "cmp": "gt", "value": "4"}, {"field": "active", "cmp": "eq", "value": "true"}]}
// account
{"nl": "show name and balance for active checking accounts", "intent": "select", "table": "account", "projections": ["name", "balance"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "type", "cmp": "eq", "value": "checking"}]}
{"nl": "get name type and balance where active and balance above 1000", "intent": "select", "table": "account", "projections": ["name", "type", "balance"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "balance", "cmp": "gt", "value": "1000"}]}
{"nl": "list name and owner where type is savings and balance below 500", "intent": "select", "table": "account", "projections": ["name", "owner"], "conditions": [{"field": "type", "cmp": "eq", "value": "savings"}, {"field": "balance", "cmp": "lt", "value": "500"}]}
// property
{"nl": "show address and price for active properties with bedrooms above 2", "intent": "select", "table": "property", "projections": ["address", "price"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "bedrooms", "cmp": "gt", "value": "2"}]}
{"nl": "get address type and bedrooms where price below 300000 and active", "intent": "select", "table": "property", "projections": ["address", "type", "bedrooms"], "conditions": [{"field": "price", "cmp": "lt", "value": "300000"}, {"field": "active", "cmp": "eq", "value": "true"}]}
{"nl": "list address price bathrooms where type is house and bedrooms above 3", "intent": "select", "table": "property", "projections": ["address", "price", "bathrooms"], "conditions": [{"field": "type", "cmp": "eq", "value": "house"}, {"field": "bedrooms", "cmp": "gt", "value": "3"}]}
// supplier
{"nl": "show name and rating for active suppliers with rating above 4", "intent": "select", "table": "supplier", "projections": ["name", "rating"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "rating", "cmp": "gt", "value": "4"}]}
{"nl": "get name email and country where active and country is Germany", "intent": "select", "table": "supplier", "projections": ["name", "email", "country"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "country", "cmp": "eq", "value": "Germany"}]}
// transaction
{"nl": "show amount and type for pending transactions above 100", "intent": "select", "table": "transaction", "projections": ["amount", "type"], "conditions": [{"field": "status", "cmp": "eq", "value": "pending"}, {"field": "amount", "cmp": "gt", "value": "100"}]}
{"nl": "get amount status and type where type is deposit and amount above 500", "intent": "select", "table": "transaction", "projections": ["amount", "status", "type"], "conditions": [{"field": "type", "cmp": "eq", "value": "deposit"}, {"field": "amount", "cmp": "gt", "value": "500"}]}
{"nl": "list amount and created where status is completed and type is transfer", "intent": "select", "table": "transaction", "projections": ["amount", "created"], "conditions": [{"field": "status", "cmp": "eq", "value": "completed"}, {"field": "type", "cmp": "eq", "value": "transfer"}]}
// review
{"nl": "show body and author for reviews with rating above 4", "intent": "select", "table": "review", "projections": ["body", "author"], "conditions": [{"field": "rating", "cmp": "gt", "value": "4"}]}
{"nl": "get rating and body where rating above 3 and rating below 5", "intent": "select", "table": "review", "projections": ["rating", "body"], "conditions": [{"field": "rating", "cmp": "gt", "value": "3"}, {"field": "rating", "cmp": "lt", "value": "5"}]}
// budget
{"nl": "show name and spent for active budgets with amount above 10000", "intent": "select", "table": "budget", "projections": ["name", "spent"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "amount", "cmp": "gt", "value": "10000"}]}
{"nl": "get name amount and spent where active and spent below amount", "intent": "select", "table": "budget", "projections": ["name", "amount", "spent"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "spent", "cmp": "lt", "value": "50000"}]}
// course
{"nl": "show name and credits for active courses with capacity above 20", "intent": "select", "table": "course", "projections": ["name", "credits"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "capacity", "cmp": "gt", "value": "20"}]}
{"nl": "get name capacity and instructor where active and credits above 2", "intent": "select", "table": "course", "projections": ["name", "capacity", "instructor"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "credits", "cmp": "gt", "value": "2"}]}
// venue
{"nl": "show name and capacity for active venues with capacity above 100", "intent": "select", "table": "venue", "projections": ["name", "capacity"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "capacity", "cmp": "gt", "value": "100"}]}
{"nl": "get name address and capacity where active and capacity below 1000", "intent": "select", "table": "venue", "projections": ["name", "address", "capacity"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "capacity", "cmp": "lt", "value": "1000"}]}
// warehouse
{"nl": "show name and location for active warehouses with capacity above 2000", "intent": "select", "table": "warehouse", "projections": ["name", "location"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "capacity", "cmp": "gt", "value": "2000"}]}
// patient
{"nl": "show name and phone for insured patients", "intent": "select", "table": "patient", "projections": ["name", "phone"], "conditions": [{"field": "insured", "cmp": "eq", "value": "true"}]}
{"nl": "get name email and insured where insured is true and email contains care", "intent": "select", "table": "patient", "projections": ["name", "email", "insured"], "conditions": [{"field": "insured", "cmp": "eq", "value": "true"}]}
// event
{"nl": "show name and capacity for open events with capacity above 200", "intent": "select", "table": "event", "projections": ["name", "capacity"], "conditions": [{"field": "status", "cmp": "eq", "value": "open"}, {"field": "capacity", "cmp": "gt", "value": "200"}]}
{"nl": "get name status and capacity where status is open and capacity below 500", "intent": "select", "table": "event", "projections": ["name", "status", "capacity"], "conditions": [{"field": "status", "cmp": "eq", "value": "open"}, {"field": "capacity", "cmp": "lt", "value": "500"}]}
// agent
{"nl": "show name and rating for active agents with rating above 4", "intent": "select", "table": "agent", "projections": ["name", "rating"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "rating", "cmp": "gt", "value": "4"}]}
{"nl": "get name email and rating where active and rating above 3.5", "intent": "select", "table": "agent", "projections": ["name", "email", "rating"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "rating", "cmp": "gt", "value": "3.5"}]}
// instructor
{"nl": "show name and department for active instructors", "intent": "select", "table": "instructor", "projections": ["name", "department"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}]}
{"nl": "get name email and department where active and department is mathematics", "intent": "select", "table": "instructor", "projections": ["name", "email", "department"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "department", "cmp": "eq", "value": "mathematics"}]}
// multi-condition + ORDER BY
{"nl": "show name and salary for active managers sorted by salary descending", "intent": "select", "table": "employee", "projections": ["name", "salary"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "role", "cmp": "eq", "value": "manager"}], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}]}
{"nl": "list active products name and price with stock above 0 ordered by price", "intent": "select", "table": "product", "projections": ["name", "price"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "stock", "cmp": "gt", "value": "0"}], "modifiers": [{"type": "order_by", "field": "price"}]}
{"nl": "get enrolled students name gpa with gpa above 3 sorted by gpa descending limit 10", "intent": "select", "table": "student", "projections": ["name", "gpa"], "conditions": [{"field": "enrolled", "cmp": "eq", "value": "true"}, {"field": "gpa", "cmp": "gt", "value": "3"}], "modifiers": [{"type": "order_by", "field": "gpa", "descending": true}, {"type": "limit", "value": "10"}]}
{"nl": "show active properties address and price with bedrooms above 2 sorted by price", "intent": "select", "table": "property", "projections": ["address", "price"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}, {"field": "bedrooms", "cmp": "gt", "value": "2"}], "modifiers": [{"type": "order_by", "field": "price"}]}
{"nl": "fetch top 5 active suppliers by rating show name and country", "intent": "select", "table": "supplier", "projections": ["name", "country"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}], "modifiers": [{"type": "order_by", "field": "rating", "descending": true}, {"type": "limit", "value": "5"}]}
