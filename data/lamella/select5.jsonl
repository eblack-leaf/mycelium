// select5.jsonl — projections combined with ORDER BY modifiers
// employee
{"nl": "list employee name and salary ordered by salary descending", "intent": "select", "table": "employee", "projections": ["name", "salary"], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}]}
{"nl": "show name email and role sorted by name", "intent": "select", "table": "employee", "projections": ["name", "email", "role"], "modifiers": [{"type": "order_by", "field": "name"}]}
{"nl": "get employees name department hired ordered by hired date", "intent": "select", "table": "employee", "projections": ["name", "department", "hired"], "modifiers": [{"type": "order_by", "field": "hired"}]}
{"nl": "fetch name and salary sorted by salary highest first", "intent": "select", "table": "employee", "projections": ["name", "salary"], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}]}
{"nl": "list active employees name role department ordered by role", "intent": "select", "table": "employee", "projections": ["name", "role", "department"], "conditions": [{"field": "active", "cmp": "eq", "value": "true"}], "modifiers": [{"type": "order_by", "field": "role"}]}
{"nl": "show top 10 highest paid employees name and salary", "intent": "select", "table": "employee", "projections": ["name", "salary"], "modifiers": [{"type": "order_by", "field": "salary", "descending": true}, {"type": "limit", "value": "10"}]}
