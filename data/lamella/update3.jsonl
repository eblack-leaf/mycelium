{"nl": "set account name to Gold and type to savings for high balance accounts", "intent": "update", "table": "account", "conditions": [{"field": "balance", "cmp": "gte", "value": "10000"}], "assignments": [{"field": "name", "value": "Gold"}, {"field": "type", "value": "savings"}, {"field": "active", "value": "true"}]}
